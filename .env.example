# Database
DATABASE_URL=postgresql://linkguard:your_password@localhost:5432/linkguard
POSTGRES_PASSWORD=your_strong_password_here

# App
SESSION_SECRET=your_random_secret_here_at_least_32_chars
NODE_ENV=production
PORT=8080

# Google Web Risk API (optional)
# Get your key at: https://console.cloud.google.com/apis/api/webrisk.googleapis.com
GOOGLE_SAFE_BROWSING_API_KEY=

# VirusTotal API (optional but strongly recommended)
# Get free key at: https://www.virustotal.com/gui/my-apikey
# Free tier: 500 lookups/day, 4 requests/min — more than enough for a Telegram bot
VIRUSTOTAL_API_KEY=

# Telegram Bot — required
# Get from @BotFather: /newbot → add bot as admin to your channel
TELEGRAM_BOT_TOKEN=

# Telegram webhook URL — full public URL to your server
# Example: https://yourdomain.com/api/webhook/telegram
# Registered automatically on server start
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/webhook/telegram

# Bot username (without @) — used in channel post buttons
# Example: BOT_USERNAME=linkguard_bot
BOT_USERNAME=

# OpenClaw Telegram channel ID (e.g. @openclaw or numeric -100xxxxxxxxxx)
OPENCLAW_CHANNEL_ID=@openclaw

# Admin chat ID — get via @userinfobot. Optional: receive reports from users.
ADMIN_CHAT_ID=
